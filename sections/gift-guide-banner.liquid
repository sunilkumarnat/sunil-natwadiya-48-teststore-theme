{% comment %}
  Gift Guide Banner — built from scratch for the Figma "Test for Candidates" hand-off.
  Structure: utility bar (logo / announcement / promo button) -> illustrated hero -> sustainability bar.
  All copy below is editable from the theme customizer.
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600&family=Lustria&display=swap" rel="stylesheet">

<section
  class="gift-banner"
  style="
    --gift-accent: {{ section.settings.accent_color }};
    --gift-dark: {{ section.settings.dark_color }};
    --gift-soft-bg: {{ section.settings.soft_bg_color }};
  "
  data-testid="gift-guide-banner"
>
  <div class="gift-banner__utility-bar">
    <p class="gift-banner__logo">{{ section.settings.logo_text }}</p>

    {% if section.settings.announcement_text != blank %}
      <p class="gift-banner__announcement">{{ section.settings.announcement_text }}</p>
    {% endif %}

    {% if section.settings.announcement_button_label != blank %}
      <a
        href="{{ section.settings.announcement_button_link | default: '#' }}"
        class="gift-banner-cta gift-banner-cta--light"
      >
        <span class="gift-banner-cta__fill" aria-hidden="true">
          <span class="gift-banner-cta__fill-label">{{ section.settings.announcement_button_label }}</span>
          {% render 'gift-guide-arrow-icon' %}
        </span>
        <span class="gift-banner-cta__label">{{ section.settings.announcement_button_label }}</span>
        {% render 'gift-guide-arrow-icon' %}
      </a>
    {% endif %}
  </div>

  <div class="gift-banner__hero">
    <div class="gift-banner__illustration" aria-hidden="true">
      <img src="{{ 'gift-guide-illustration.svg' | asset_url }}" alt="" width="1440" height="780" loading="eager">
    </div>

    <div class="gift-banner__content">
      {% if section.settings.heading != blank %}
        <h2 class="gift-banner__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="gift-banner__description">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="gift-banner-cta gift-banner-cta--dark"
        >
          <span class="gift-banner-cta__fill" aria-hidden="true">
            <span class="gift-banner-cta__fill-label">{{ section.settings.button_label }}</span>
            {% render 'gift-guide-arrow-icon' %}
          </span>
          <span class="gift-banner-cta__label">{{ section.settings.button_label }}</span>
          {% render 'gift-guide-arrow-icon' %}
        </a>
      {% endif %}
    </div>
  </div>

  {% if section.settings.sustainability_text != blank %}
    <div class="gift-banner__utility-bar gift-banner__utility-bar--bottom">
      <p class="gift-banner__sustainability">
        <span class="gift-banner__sustainability-desktop">{{ section.settings.sustainability_text }}</span>
        <span class="gift-banner__sustainability-mobile">
          {{ section.settings.sustainability_text_mobile | default: section.settings.sustainability_text }}
        </span>
      </p>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .gift-banner {
    --gift-accent: #fff544;
    --gift-dark: #000000;
    --gift-soft-bg: #f5f5f5;
    font-family: 'Jost', sans-serif;
    color: var(--gift-dark);
    background: #ffffff;
    overflow: hidden;
  }

  .gift-banner__utility-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: var(--gift-soft-bg);
    padding: 10px 50px;
    min-height: 64px;
  }

  .gift-banner__utility-bar--bottom {
    min-height: 34px;
    padding: 10px 50px;
    justify-content: center;
  }

  .gift-banner__logo {
    margin: 0;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .gift-banner__announcement {
    margin: 0;
    font-size: 1rem;
    text-align: center;
    flex: 1;
  }

  .gift-banner__sustainability {
    margin: 0;
    font-size: 1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
  }

  .gift-banner__sustainability-mobile {
    display: none;
  }

  .gift-banner__hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 780px;
    padding: 0 50px;
  }

  .gift-banner__illustration {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.5;
  }

  .gift-banner__illustration img {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
  }

  .gift-banner__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    max-width: 500px;
  }

  /* Legibility scrim: fades the illustration behind the text without hiding it outright */
  .gift-banner__content::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -40px -60px -40px -100vw;
    background: linear-gradient(to right, #ffffff 60%, rgba(255, 255, 255, 0.85) 85%, rgba(255, 255, 255, 0) 100%);
  }

  .gift-banner__heading {
    margin: 0;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-size: 4.375rem;
    line-height: 1;
  }

  .gift-banner__description {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.4;
  }

  .gift-banner__description p {
    margin: 0;
  }

  /* Shared "fill sweep" CTA button — matches the Figma smart-animate hover state */
  .gift-banner-cta,
  .gift-banner-cta *,
  .gift-banner-cta *::before,
  .gift-banner-cta *::after {
    box-sizing: border-box;
  }

  .gift-banner-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 50px;
    padding: 0 24px;
    text-decoration: none;
    text-transform: uppercase;
    font-family: 'Jost', sans-serif;
    font-size: 1rem;
    white-space: nowrap;
    overflow: hidden;
  }

  .gift-banner-cta__fill,
  .gift-banner-cta__label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .gift-banner-cta__fill {
    position: absolute;
    inset: 0;
    padding: 0 24px;
    overflow: hidden;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.35s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .gift-banner-cta:hover .gift-banner-cta__fill {
    clip-path: inset(0 0 0 0);
  }

  .gift-banner-cta--dark {
    background: var(--gift-dark);
    color: #f5f5f5;
  }

  .gift-banner-cta--dark .gift-banner-cta__fill {
    background: var(--gift-accent);
    color: var(--gift-dark);
  }

  .gift-banner-cta--light {
    height: 44px;
    background: var(--gift-accent);
    color: var(--gift-dark);
  }

  .gift-banner-cta--light .gift-banner-cta__fill {
    background: var(--gift-dark);
    color: var(--gift-accent);
  }

  .gift-cta__arrow {
    width: 24px;
    height: 10px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .gift-banner__utility-bar {
      padding: 16px;
    }

    .gift-banner__announcement,
    .gift-banner__utility-bar > .gift-banner-cta {
      display: none;
    }

    .gift-banner__utility-bar--bottom {
      padding: 8px 16px;
    }

    .gift-banner__sustainability {
      font-size: 0.875rem;
    }

    .gift-banner__sustainability-desktop {
      display: none;
    }

    .gift-banner__sustainability-mobile {
      display: inline;
    }

    .gift-banner__hero {
      min-height: 640px;
      padding: 32px 20px;
      justify-content: center;
      text-align: center;
    }

    .gift-banner__illustration {
      opacity: 0.35;
    }

    .gift-banner__content::before {
      inset: -24px -24px;
      background: radial-gradient(ellipse, #ffffff 55%, rgba(255, 255, 255, 0.8) 75%, rgba(255, 255, 255, 0) 100%);
    }

    .gift-banner__content {
      align-items: center;
      max-width: 100%;
      gap: 16px;
    }

    .gift-banner__heading {
      font-size: 1.875rem;
    }

    .gift-banner__description {
      font-size: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gift Guide Banner",
  "settings": [
    {
      "type": "header",
      "content": "Utility bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Tisso Vison"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "announcement_button_label",
      "label": "Announcement button label",
      "default": "Choose Gift"
    },
    {
      "type": "url",
      "id": "announcement_button_link",
      "label": "Announcement button link"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Sustainability bar"
    },
    {
      "type": "text",
      "id": "sustainability_text",
      "label": "Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "text",
      "id": "sustainability_text_mobile",
      "label": "Text (mobile override)",
      "info": "Leave blank to reuse the text above.",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#FFF544"
    },
    {
      "type": "color",
      "id": "dark_color",
      "label": "Dark",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "soft_bg_color",
      "label": "Bar background",
      "default": "#F5F5F5"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}
