{% comment %}
  Gift Header — built from scratch for the Figma "Test for Candidates" hand-off.
  A promo bar (logo / announcement / CTA) rendered globally via the header group, separate from
  the Gift Guide Banner section so it appears above every page, not just one. On desktop the
  whole bar is always visible inline. On mobile it behaves like a menu toggle: the announcement
  + CTA are collapsed behind a burger trigger (morphing to an ×), with the logo centered,
  closed by default on every page load, and open/close on tap — no dismissal state is
  remembered between loads.
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;600&display=swap" rel="stylesheet">

<div
  class="gift-header"
  style="
    --gift-accent: {{ section.settings.accent_color }};
    --gift-dark: {{ section.settings.dark_color }};
    --gift-soft-bg: {{ section.settings.soft_bg_color }};
  "
  data-testid="gift-header"
>
  <div class="gift-header__bar">
    <div class="gift-header__row gift-header__row--top">
      <button
        type="button"
        class="gift-header__toggle"
        data-gift-header-toggle
        aria-expanded="false"
        aria-controls="GiftHeaderContent-{{ section.id }}"
        aria-label="Toggle gift offer"
      >
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <line class="gift-header__toggle-line gift-header__toggle-line--top" x1="0" y1="1" x2="18" y2="1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line class="gift-header__toggle-line gift-header__toggle-line--middle" x1="0" y1="7" x2="18" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line class="gift-header__toggle-line gift-header__toggle-line--bottom" x1="0" y1="13" x2="18" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
      <p class="gift-header__logo">{{ section.settings.logo_text }}</p>
    </div>

    <div class="gift-header__row gift-header__row--bottom" id="GiftHeaderContent-{{ section.id }}">
      {% if section.settings.announcement_text != blank %}
        <p class="gift-header__announcement">
          <span class="gift-header__announcement-desktop">{{ section.settings.announcement_text }}</span>
          <span class="gift-header__announcement-mobile">
            {{ section.settings.announcement_text_mobile | default: section.settings.announcement_text }}
          </span>
        </p>
      {% endif %}

      {% if section.settings.announcement_button_label != blank %}
        <a
          href="{{ section.settings.announcement_button_link | default: '#' }}"
          class="gift-header-cta gift-header-cta--light"
        >
          <span class="gift-header-cta__fill" aria-hidden="true">
            <span class="gift-header-cta__fill-label">{{ section.settings.announcement_button_label }}</span>
            {% render 'gift-guide-arrow-icon' %}
          </span>
          <span class="gift-header-cta__label">{{ section.settings.announcement_button_label }}</span>
          {% render 'gift-guide-arrow-icon' %}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<script src="{{ 'gift-header.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .gift-header {
    font-family: 'Jost', sans-serif;
    color: var(--gift-dark, #000000);
    background: var(--gift-soft-bg, #f5f5f5);
  }

  .gift-header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 10px 50px;
    min-height: 64px;
  }

  .gift-header__row {
    display: contents;
  }

  .gift-header__toggle {
    display: none;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--gift-dark, #000000);
    cursor: pointer;
  }

  .gift-header__toggle-line {
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .gift-header__toggle[aria-expanded='true'] .gift-header__toggle-line--top {
    transform: translateY(6px) rotate(45deg);
  }

  .gift-header__toggle[aria-expanded='true'] .gift-header__toggle-line--middle {
    opacity: 0;
  }

  .gift-header__toggle[aria-expanded='true'] .gift-header__toggle-line--bottom {
    transform: translateY(-6px) rotate(-45deg);
  }

  .gift-header__logo {
    margin: 0;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .gift-header__announcement {
    margin: 0;
    font-size: 1rem;
    text-align: center;
    flex: 1;
  }

  .gift-header__announcement-mobile {
    display: none;
  }

  /* Shared "fill sweep" CTA button — same mechanism as the other Gift Guide sections */
  .gift-header-cta,
  .gift-header-cta *,
  .gift-header-cta *::before,
  .gift-header-cta *::after {
    box-sizing: border-box;
  }

  .gift-header-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 44px;
    padding: 0 24px;
    text-decoration: none;
    text-transform: uppercase;
    font-family: 'Jost', sans-serif;
    font-size: 1rem;
    white-space: nowrap;
    overflow: hidden;
  }

  .gift-header-cta__fill,
  .gift-header-cta__label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .gift-header-cta__fill {
    position: absolute;
    inset: 0;
    padding: 0 24px;
    overflow: hidden;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.35s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .gift-header-cta:hover .gift-header-cta__fill {
    clip-path: inset(0 0 0 0);
  }

  .gift-header-cta--light {
    background: var(--gift-accent, #fff544);
    color: var(--gift-dark, #000000);
  }

  .gift-header-cta--light .gift-header-cta__fill {
    background: var(--gift-dark, #000000);
    color: var(--gift-accent, #fff544);
  }

  @media screen and (max-width: 749px) {
    .gift-header__bar {
      flex-direction: column;
      align-items: stretch;
      padding: 0;
      gap: 0;
      min-height: 0;
    }

    .gift-header__row {
      display: flex;
    }

    .gift-header__row--top {
      position: relative;
      justify-content: center;
      align-items: center;
      padding: 10px;
      box-shadow: 1px 1px 12px #00000029;
      background: #F7F7F7;
    }

    .gift-header__row--bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      background: #f2f2f2;
      /* Closed by default on every page load — no state is remembered between loads.
         Driven entirely by the .is-open class; JS only ever toggles that class. */
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      gap: 0;
      padding: 0 10px;
      transition: max-height 0.3s ease, opacity 0.3s ease, padding 0.3s ease, gap 0.3s ease;
    }

    .gift-header__row--bottom.is-open {
      max-height: 220px;
      opacity: 1;
      gap: 12px;
      padding: 15px 10px;
    }

    .gift-header__toggle {
      display: inline-flex;
      position: absolute;
      left: 15px;
      top: 50%;
      transform: translateY(-50%);
    }

    .gift-header__announcement {
      flex: none;
    }

    .gift-header__announcement-desktop {
      display: none;
    }

    .gift-header__announcement-mobile {
      display: inline;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gift Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Tisso Vison"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "announcement_text_mobile",
      "label": "Announcement text (mobile override)",
      "info": "Leave blank to reuse the text above.",
      "default": "Get started with your \"Mi Solo\" kit"
    },
    {
      "type": "text",
      "id": "announcement_button_label",
      "label": "Button label",
      "default": "Choose Gift"
    },
    {
      "type": "url",
      "id": "announcement_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#FFF544"
    },
    {
      "type": "color",
      "id": "dark_color",
      "label": "Dark",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "soft_bg_color",
      "label": "Bar background",
      "default": "#F5F5F5"
    }
  ],
  "presets": [
    {
      "name": "Gift Header"
    }
  ]
}
{% endschema %}
